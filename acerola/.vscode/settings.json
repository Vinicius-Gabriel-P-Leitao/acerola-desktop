{
  "svelte.enable-ts-plugin": true,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.readonlyInclude": {
    "**/lib/rustlib/src/rust/library/**/*.rs": true,
    "**/.cargo/git/checkouts/**/*.rs": true,
    "**/.cargo/registry/src/**/*.rs": true
  },
  "files.watcherExclude": {
    "**/target/**": true
  },
  "files.exclude": {
    "**/paraglide": true,
    "**/target": true,
    "**/build": true,
    "**/gen": true,
    "**/capabilities": true,
    "**/project.inlang": true,
    "**/node_modules": true,
    "**/.svelte-kit": true
  },
  "search.exclude": {
    "**/target": true,
    "**/build": true,
    "**/gen": true,
    "**/paraglide": true,
    "**/capabilities": true,
    "**/project.inlang": true,
    "**/node_modules": true,
    "**/.svelte-kit": true
  },
  "material-icon-theme.files.customClones": [
    {
      "name": "rust-lib",
      "color": "cyan",
      "base": "rust"
    },
    {
      "name": "rust-mod",
      "color": "green",
      "base": "rust"
    }
  ],
  "material-icon-theme.files.associations": {
    "lib.rs": "rust-lib",
    "mod.rs": "rust-mod"
  },
  "material-icon-theme.folders.associations": {
    "network": "connection",
    "summary": "docs",
    "peer": "client",
    "p2p": "client"
  }
}
