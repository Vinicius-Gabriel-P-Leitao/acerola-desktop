{
  "svelte.enable-ts-plugin": true,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.readonlyInclude": {
    "**/.cargo/registry/src/**/*.rs": true,
    "**/.cargo/git/checkouts/**/*.rs": true,
    "**/lib/rustlib/src/rust/library/**/*.rs": true
  },
  "files.watcherExclude": {
    "**/target/**": true
  },
  "files.exclude": {
    "**/project.inlang": true,
    "**/capabilities": true,
    "**/node_modules": true,
    "**/.svelte-kit": true,
    "**/paraglide": true,
    "**/target": true,
    "**/build": true,
    "**/gen": true
  },
  "search.exclude": {
    "**/project.inlang": true,
    "**/capabilities": true,
    "**/node_modules": true,
    "**/.svelte-kit": true,
    "**/paraglide": true,
    "**/target": true,
    "**/build": true,
    "**/gen": true
  },
  "cSpell.words": [
    "anilist",
    "axum",
    "catppuccin",
    "dracula",
    "inlang",
    "mangadex",
    "mdns",
    "nord",
    "outdir",
    "paraglide",
    "poppanator",
    "recv",
    "serde",
    "sqlite",
    "Sqlite",
    "sqlx",
    "strs",
    "subdirs",
    "tauri",
    "thiserror",
    "tokio",
    "unlisten"
  ]
}
