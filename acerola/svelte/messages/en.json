          },
          "deep": {
            "title": "Deep synchronization",
            "desc": "Rewrites all archive from the database."
          }
        }
      },
      "metadata": {
        "title": "Metadata configuration",
        "lang": {
          "title": "Language",
          "desc": "Select the default language for metadata."
        },
        "mangadex": {
          "title": "MangaDex Synchronization",
          "desc": "Synchronize metadata with MangaDex."
        },
        "anilist": {
          "title": "AniList Synchronization",
          "desc": "Synchronize metadata with AniList."
        }
      },
      "components": {
        "theme_piker": "Appearance"
      }
    }
  }
