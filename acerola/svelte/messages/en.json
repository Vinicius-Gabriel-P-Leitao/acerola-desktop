{
  "$schema": "https://inlang.com/schema/inlang-message-format",
  "theme": {
    "catppuccin": {
      "name": "Catppuccin",
      "desc": "Soft pastel palette with purple and pink tones"
    },
    "nord": {
      "name": "Nord",
      "desc": "Arctic palette inspired by Scandinavia"
    },
    "dracula": {
      "name": "Dracula",
      "desc": "Vibrant colors on dark or light backgrounds"
    }
  },
  "components": {
    "hero_button": {
      "default_title": "Untitled"
    },
    "select": {
      "placeholder": "Select an option"
    },
    "popover": {
      "close": "Close"
    },
    "command": {
      "placeholder": "Search..."
    }
  },
  "routes": {
    "home": "Home",
    "history": "History",
    "config": "Settings"
