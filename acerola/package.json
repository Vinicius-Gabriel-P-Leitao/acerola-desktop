{
  "name": "acerola",
  "type": "module",
  "version": "0.0.1-beta",
  "license": "GPL-3.0-only",
  "author": {
    "name": "Vinícius Gabriel Pereira Leitão",
    "email": "vinicius.gabriel.p.leitao@gmail.com"
  },
  "description": "Aplicativo para ler e gerenciar bibliotecas de quadrinhos locais.",
  "scripts": {
    "tauri": "tauri",
    "preview": "vite preview",
    "dev": "npm run paraglide:compile && vite dev",
    "build": "npm run paraglide:compile && vite build",
    "check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test": "npm run test:unit -- --run && vitest run",
    "storybook": "npm run paraglide:compile && storybook dev -p 6006",
    "build-storybook": "npm run paraglide:compile && storybook build",
    "paraglide:compile": "paraglide-js compile --project ./svelte/project.inlang --outdir ./svelte/src/lib/paraglide"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@inlang/paraglide-js": "^2.10.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@poppanator/sveltekit-svg": "^6.0.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/sveltekit": "^10.3.4",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "jsdom": "^29.0.1",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "shadcn-svelte": "^1.2.6",
    "storybook": "^10.3.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  }
}
